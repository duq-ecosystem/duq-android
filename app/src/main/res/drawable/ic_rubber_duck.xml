<!--
  Каноническая резиновая утка — душевная премиум-версия (ванная игрушка).
  Объёмные радиальные градиенты тела/головы, глянцевые блики-стрики (как настоящая
  резина), живой глянцевый глаз с тёплым рефлексом (в нём «душа»), добрая улыбка,
  лёгкий румянец, опрятный хохолок, мягкое отражение снизу. Пропорции/градиенты
  выверены растеризацией SVG. circle/ellipse — path-арки; градиенты — aapt:attr.
  НЕ рисовать от руки Canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="120dp"
    android:height="118dp"
    android:viewportWidth="120"
    android:viewportHeight="118">

    <!-- мягкое отражение под уткой -->
    <path android:fillColor="#FFD42E" android:fillAlpha="0.10"
        android:pathData="M24,109 a30,4 0 1 0 60,0 a30,4 0 1 0 -60,0 Z" />

    <!-- хвост-флип -->
    <path android:pathData="M30,67 C22,64 16,58 18,51 C24,54 28,60 33,66 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="46" android:centerY="76" android:gradientRadius="53">
                <item android:offset="0" android:color="#FFFFEC8A" />
                <item android:offset="0.5" android:color="#FFFFD42E" />
                <item android:offset="1" android:color="#FFE8AE00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- тело -->
    <path android:pathData="M21,85 a33,23 0 1 0 66,0 a33,23 0 1 0 -66,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="46" android:centerY="76" android:gradientRadius="53">
                <item android:offset="0" android:color="#FFFFEC8A" />
                <item android:offset="0.5" android:color="#FFFFD42E" />
                <item android:offset="1" android:color="#FFE8AE00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- хохолок -->
    <path android:pathData="M76,21 C74,12 81,10 85,14 C81,15 79,18 79,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="72" android:centerY="32" android:gradientRadius="38">
                <item android:offset="0" android:color="#FFFFF0A0" />
                <item android:offset="0.5" android:color="#FFFFD42E" />
                <item android:offset="1" android:color="#FFE8AE00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- голова -->
    <path android:pathData="M56,42 a23,23 0 1 0 46,0 a23,23 0 1 0 -46,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="72" android:centerY="32" android:gradientRadius="38">
                <item android:offset="0" android:color="#FFFFF0A0" />
                <item android:offset="0.5" android:color="#FFFFD42E" />
                <item android:offset="1" android:color="#FFE8AE00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- глянцевый блик на голове -->
    <path android:pathData="M56,31 a11,8 0 1 0 22,0 a11,8 0 1 0 -22,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="67" android:centerY="31" android:gradientRadius="11">
                <item android:offset="0" android:color="#8CFFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- глянцевый блик на теле -->
    <path android:pathData="M29,74 a14,7 0 1 0 28,0 a14,7 0 1 0 -28,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="43" android:centerY="74" android:gradientRadius="14">
                <item android:offset="0" android:color="#8CFFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- сложенное крыло -->
    <path android:strokeColor="#D99E00" android:strokeWidth="2.4" android:strokeLineCap="round" android:strokeAlpha="0.8"
        android:pathData="M36,82 C47,76 59,79 61,90" />

    <!-- клювик -->
    <path android:pathData="M98,45 C109,43 116,46 116,50 C116,55 109,58 99,56 C95,55 95,46 98,45 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="107" android:startY="43" android:endX="107" android:endY="58">
                <item android:offset="0" android:color="#FFFFB845" />
                <item android:offset="1" android:color="#FFF58A0C" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- добрая улыбка -->
    <path android:strokeColor="#DC7800" android:strokeWidth="1.3" android:strokeLineCap="round"
        android:pathData="M99,53 C104,55 110,55 114,52" />

    <!-- румянец -->
    <path android:fillColor="#FF8FA6" android:fillAlpha="0.45"
        android:pathData="M68,52 a6,4 0 1 0 12,0 a6,4 0 1 0 -12,0 Z" />

    <!-- глаз: большой, живой, глянцевый -->
    <path android:pathData="M79.4,39 a5.6,6 0 1 0 11.2,0 a5.6,6 0 1 0 -11.2,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="83" android:centerY="37" android:gradientRadius="10">
                <item android:offset="0" android:color="#FF4A4036" />
                <item android:offset="0.6" android:color="#FF241F1A" />
                <item android:offset="1" android:color="#FF120F0C" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- катчлайты -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M80.2,36.3 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0 Z" />
    <path android:fillColor="#FFFFFF" android:fillAlpha="0.9"
        android:pathData="M85.5,41.2 a1.1,1.1 0 1 0 2.2,0 a1.1,1.1 0 1 0 -2.2,0 Z" />
    <!-- тёплый нижний рефлекс — «душа» -->
    <path android:fillColor="#7A6A52" android:fillAlpha="0.5"
        android:pathData="M82.6,42 a2.4,1.2 0 1 0 4.8,0 a2.4,1.2 0 1 0 -4.8,0 Z" />
</vector>
